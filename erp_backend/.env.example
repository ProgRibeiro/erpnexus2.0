# ========================================
# Exemplo de arquivo .env para o ERP
# ========================================
# Copie este arquivo como .env e preencha com suas configurações

# ========================================
# Banco de Dados
# ========================================
DB_NAME=erp_db
DB_USER=postgres
DB_PASSWORD=sua_senha_postgres
DB_HOST=localhost
DB_PORT=5432

# ========================================
# Django
# ========================================
SECRET_KEY=sua-chave-secreta-bem-segura-aqui
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Segurança para uso real/produção local exposta
# Em teste local com HTTP, mantenha False/0.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760

# ========================================
# JWT Tokens
# ========================================
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# ========================================
# CORS
# ========================================
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ========================================
# SMTP - Email Configuration
# ========================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=seu-email@gmail.com
EMAIL_HOST_PASSWORD=sua-senha-app-especifica
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=seu-email@gmail.com

# ========================================
# NOTIFICACOES - Emails Administrativos
# ========================================
ADMIN_EMAIL=admin@sua-empresa.com
FINANCEIRO_EMAIL=financeiro@sua-empresa.com
ESTOQUE_EMAIL=estoque@sua-empresa.com

# ========================================
# NOTIFICACOES - WhatsApp (ESCOLHA UM)
# ========================================

# Opção 1: CallMeBot (mais simples, sem backend)
WHATSAPP_PROVEDOR=callmebot
CALLMEBOT_APIKEY=sua-api-key-callmebot-aqui

# Opção 2: Z-API (mais robusto)
# WHATSAPP_PROVEDOR=zapi
# ZAPI_INSTANCIA=sua-instancia-z-api
# ZAPI_TOKEN=seu-token-z-api

# ========================================
# URLs Base
# ========================================
BASE_URL=http://localhost:5173

# ========================================
# Redis (para Celery)
# ========================================
REDIS_URL=redis://localhost:6379/0

# ========================================
# Backups locais
# ========================================
ERP_BACKUP_DIR=C:\ERP_BACKUPS\ERP_NEXUS
ERP_BACKUP_RETENTION_DAYS=30

# ========================================
# AWS S3 (OPCIONAL)
# ========================================
USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=
# AWS_DEFAULT_ACL=public-read
# AWS_QUERYSTRING_AUTH=False

# ========================================
# Notas de Configuração
# ========================================
#
# GMAIL:
# 1. Ativar 2FA na conta Google
# 2. Gerar "Senha de Aplicativo" em:
#    https://myaccount.google.com/apppasswords
# 3. Copiar a senha para EMAIL_HOST_PASSWORD
#
# WhatsApp CallMeBot:
# 1. Enviar mensagem "I allow callmebot to send me messages" para WhatsApp
# 2. Copiar a API Key fornecida
#
# WhatsApp Z-API:
# 1. Criar conta em https://z-api.io/
# 2. Conectar WhatsApp Business
# 3. Copiar dados de instância e token
#
