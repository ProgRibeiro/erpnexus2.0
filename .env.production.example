# Copie para erp_backend/.env e substitua todos os valores de exemplo.
# Produção local Windows: mantenha HTTPS=False e acesso em 127.0.0.1.
# Exposição na internet: use proxy HTTPS e ative as opções seguras abaixo.

# Django
DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
BASE_URL=http://localhost:8000

# Database Configuration
DB_NAME=erp_db
DB_USER=postgres
DB_PASSWORD=change-this-database-password
DB_HOST=localhost
DB_PORT=5432

# Redis Configuration
REDIS_PASSWORD=redis-secure-password
REDIS_URL=redis://:redis-secure-password@localhost:6379/0

# Email Configuration (Gmail example)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=noreply@example.com
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# AWS S3 Configuration (if using S3 for file uploads)
USE_S3=False
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=cdn.example.com

# Application Settings
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7
MEDIA_URL=/media/
MEDIA_ROOT=media
ERP_BACKUP_DIR=C:\ERP_BACKUPS\ERP_NEXUS
ERP_BACKUP_RETENTION_DAYS=30
