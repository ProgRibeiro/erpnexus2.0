# Django Settings
DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production
DJANGO_SETTINGS_MODULE=config.settings
ALLOWED_HOSTS=example.com,www.example.com,localhost,127.0.0.1

# Database Configuration
DB_NAME=erp_db
DB_USER=erp_user
DB_PASSWORD=secure-password-here
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://erp_user:secure-password-here@localhost:5432/erp_db

# Redis Configuration
REDIS_PASSWORD=redis-secure-password
REDIS_URL=redis://:redis-secure-password@localhost:6379/0

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com

# Frontend Configuration
VITE_API_BASE_URL=/api/v1

# Email Configuration (Gmail example)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=noreply@example.com

# AWS S3 Configuration (if using S3 for file uploads)
USE_S3=False
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=cdn.example.com

# Application Settings
TIME_ZONE=America/Sao_Paulo
LANGUAGE_CODE=pt-br
