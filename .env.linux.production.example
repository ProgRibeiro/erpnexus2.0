# ERP Nexus - exemplo seguro para servidor Linux local/on-premise
# Copie para erp_backend/.env somente se for configurar manualmente.
# O script scripts/linux/instalar_producao_local.sh gera este arquivo sozinho.

DEBUG=False
SECRET_KEY=troque-por-uma-chave-gerada-com-openssl-rand-hex-32

# Acesso publico
ERP_DOMAIN=erp.exemplo.com
BASE_URL=https://erp.exemplo.com
DJANGO_ALLOWED_HOSTS=erp.exemplo.com,localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=https://erp.exemplo.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://erp.exemplo.com

# Banco PostgreSQL local
DB_NAME=erp_nexus
DB_USER=erp_nexus
DB_PASSWORD=troque-por-senha-forte
DB_HOST=127.0.0.1
DB_PORT=5432

# Redis local protegido por senha
REDIS_PASSWORD=troque-por-senha-forte
REDIS_URL=redis://:troque-por-senha-forte@127.0.0.1:6379/0

# Cookies e HTTPS
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False

# Uploads e backups locais
MEDIA_URL=/media/
MEDIA_ROOT=media
ERP_BACKUP_DIR=/var/backups/erp-nexus
ERP_BACKUP_RETENTION_DAYS=30
ERP_BACKUP_ENCRYPTION_PASSPHRASE=troque-por-frase-longa

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=7

# Email opcional
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=

# Administracao inicial gerada pelo instalador
LINUX_ADMIN_EMAIL=admin@erp.local
LINUX_ADMIN_PASSWORD=troque-por-senha-forte
MASTER_ADMIN_EMAIL=admin@erp.local
MASTER_ADMIN_PASSWORD=troque-por-senha-forte
